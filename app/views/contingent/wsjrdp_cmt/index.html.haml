:css
  .p-chip {
    display: inline-block;
    vertical-align: baseline;
    /*box-sizing: border-box;*/
    padding: 1px 4px;
    margin: 1px 3px;
    /*font-size: 13px;*/
    border-radius: 6px;
    background-color: #e8ebf0aa;
    white-space: nowrap;
    /*overflow: hidden;*/
  }
  .tag-hoc, .tag-ehoc {
    font-weight: 300 !important;
    position: relative;
    bottom: 0.25em;
    font-size: 75%;
    padding: 0px 2px;
    border-radius: 2px;
    color: #a16a18;
    background-color: #fef5d5;
  }
  .tag-jpt {
    font-weight: 300 !important;
    position: relative;
    bottom: 0.25em;
    font-size: 75%;
    padding: 0px 2px;
    border-radius: 2px;
    color: #398bf1;
    background-color: #a2ceff;
  }
  .team-people-list + .team-people-list {
    margin-left: 10px;
  }

#main.row
  %h1 German Contingent

  %h2
    %a{href: group_people_path(1)}
      CMT-Mitglieder

  %table.table.table-striped.table-hover
    %thead
      %tr
        %th Team
        %th Personen
        %th Anzahl
    %tbody
      - @tag_names.each do |tag_name|
        = render 'team', tag_name: tag_name
      = render 'group_row', label: "JPT auf dem WSJ", people_with_labels: [[nil, @wsj_role_jpt_people]]
      = render 'group_row', label: "CMT auf dem WSJ", people_with_labels: [[nil, @wsj_role_cmt_people]]
      - if @wsj_role_other_people.size > 0
        = render 'group_row', label: "andere Rolle auf dem WSJ", people_with_labels: [[nil, @wsj_role_other_people]]
