%tr
  %td
    = label
  %td
    - count_people = 0
    - people_with_labels.each do |label, people|
      - count_people += people.size
      - if people.size > 0
        %span.team-people-list
          %span.fw-light.muted
            = label
          = people_chips(people)
  %td= count_people
